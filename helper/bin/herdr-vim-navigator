#!/usr/bin/env python3
"""Standalone entry point for herdr-vim-navigator.

This thin wrapper lets you run the CLI without installing the package — symlink it
onto your PATH for local/dev use:

    ln -sf "$PWD/bin/herdr-vim-navigator" ~/.local/bin/herdr-vim-navigator

Installed copies (pip / pipx / uv tool) get the same CLI via the
``herdr-vim-navigator`` console script declared in pyproject.toml.
"""

import sys
from pathlib import Path

# Resolve through any symlink so the package import works even when this script is
# symlinked onto PATH (e.g. ~/.local/bin/herdr-vim-navigator).
_REPO_ROOT = Path(__file__).resolve().parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

from herdr_vim_navigator.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
